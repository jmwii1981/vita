# Ignore macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear on external disk drives
.Spotlight-V100
.Trashes

# macOS-specific cache files
*.swp
*.lock
*.DS_Store

# Ignore Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore IDE/editor-specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore Python compiled files
*.pyc
*.pyo
__pycache__/

# Ignore log files and temporary files
*.log
*.tmp

# Ignore build and dependency directories
build/
dist/
tmp/
out/

# Ignore package-lock and yarn lock (optional if you want to commit lock files)
# package-lock.json
# yarn.lock

# Ignore Git directories
.git/

# Ignore environment variable files
.env
.env.local
.env.*.local

# Ignore macOS resource fork files
.Spotlight-V100/
.Trashes/

